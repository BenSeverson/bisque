{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate is scoped to ONLY the ESP-IDF version regex below — the one dependency Dependabot can't see (it lives in workflow YAML, not a manifest). npm and GitHub Actions stay with Dependabot (.github/dependabot.yml); enabledManagers keeps Renovate from opening duplicate PRs for them.",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "enabledManagers": ["custom.regex"],
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "prConcurrentLimit": 3,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": [
        "esp_idf_version:\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "espressif/esp-idf",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["espressif/esp-idf"],
      "commitMessagePrefix": "chore(idf):",
      "groupName": "esp-idf"
    }
  ]
}

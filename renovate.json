{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate complements Dependabot for what Dependabot can't see: the ESP-IDF version is a string inside workflow YAML, not a package manifest entry, so only a regex manager catches it. Install the Renovate GitHub App on this repo to enable.",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 9am on monday"],
  "prConcurrentLimit": 3,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": [
        "esp_idf_version:\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "espressif/esp-idf",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["espressif/esp-idf"],
      "commitMessagePrefix": "chore(idf):",
      "groupName": "esp-idf"
    }
  ]
}
